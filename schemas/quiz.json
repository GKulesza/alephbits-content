{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alephbits.org/schemas/quiz.json",
  "title": "AlephBits Reading Pack Quiz",
  "description": "quiz.json — optional comprehension questions for a reading pack.",
  "type": "object",
  "required": ["questions"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/question" }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": ["type", "question", "answers", "correctIndex"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["single_choice"] },
        "question": { "type": "string", "minLength": 1 },
        "answers": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "correctIndex": { "type": "integer", "minimum": 0 },
        "explanation": { "type": "string" }
      }
    }
  }
}
