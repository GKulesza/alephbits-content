{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alephbits.org/schemas/repo-manifest.json",
  "title": "AlephBits Content Repository Manifest",
  "description": "Top-level catalog describing the alephbits-content library.",
  "type": "object",
  "required": [
    "repositoryVersion",
    "schemaVersion",
    "minimumAppVersion",
    "generatedAt",
    "officialPackCount",
    "communityPackCount",
    "experimentalPackCount",
    "supportedLanguages",
    "supportedWritingSystems",
    "categories",
    "featuredCollections",
    "libraryStatistics",
    "packs"
  ],
  "additionalProperties": false,
  "properties": {
    "repositoryVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the repository catalog as a whole."
    },
    "schemaVersion": {
      "type": "string",
      "description": "Version of the manifest schema contract."
    },
    "minimumAppVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Lowest AlephBits app version that can consume this manifest."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when manifest.json was last generated."
    },
    "officialPackCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of packs under official/ indexed in packs."
    },
    "communityPackCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of packs under community/ indexed in packs."
    },
    "experimentalPackCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of packs under experimental/ indexed in packs."
    },
    "supportedLanguages": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "minItems": 1,
      "uniqueItems": true,
      "description": "BCP 47 language codes with at least one published pack."
    },
    "supportedWritingSystems": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Writing system IDs matching AlephBits engine assets."
    },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/$defs/category" },
      "description": "Discovery categories available in the library."
    },
    "featuredCollections": {
      "type": "array",
      "items": { "$ref": "#/$defs/collection" },
      "description": "Curated shelves shown in discovery surfaces."
    },
    "packs": {
      "type": "array",
      "items": { "$ref": "#/$defs/packEntry" },
      "description": "Flat index of all published packs."
    },
    "libraryStatistics": {
      "type": "object",
      "description": "Aggregate library metrics for discovery and editorial dashboards.",
      "required": [
        "totalPacks",
        "totalWords",
        "totalEstimatedReadingTimeMinutes",
        "languageCount",
        "writingSystemCount",
        "categoryCount",
        "largestPack",
        "newestPack",
        "oldestPack"
      ],
      "additionalProperties": false,
      "properties": {
        "totalPacks": { "type": "integer", "minimum": 0 },
        "totalWords": { "type": "integer", "minimum": 0 },
        "totalEstimatedReadingTimeMinutes": { "type": "integer", "minimum": 0 },
        "languageCount": { "type": "integer", "minimum": 0 },
        "writingSystemCount": { "type": "integer", "minimum": 0 },
        "categoryCount": { "type": "integer", "minimum": 0 },
        "largestPack": { "$ref": "#/$defs/packStatRef" },
        "newestPack": { "$ref": "#/$defs/packDateRef" },
        "oldestPack": { "$ref": "#/$defs/packDateRef" }
      }
    }
  },
  "$defs": {
    "packStatRef": {
      "type": "object",
      "required": ["id", "bookId", "wordCount"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "bookId": { "type": "string" },
        "wordCount": { "type": "integer", "minimum": 0 }
      }
    },
    "packDateRef": {
      "type": "object",
      "required": ["id", "bookId", "updated"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "bookId": { "type": "string" },
        "updated": { "type": "string", "format": "date" }
      }
    },
    "category": {
      "type": "object",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "collection": {
      "type": "object",
      "required": ["id", "title", "packIds"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "packIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "packEntry": {
      "type": "object",
      "required": [
        "id",
        "bookId",
        "path",
        "tier",
        "writingSystem",
        "language",
        "title",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "bookId": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "tier": { "type": "string", "enum": ["official", "community", "experimental"] },
        "writingSystem": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 2 },
        "title": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 10 },
        "estimatedReadingTime": { "type": "integer", "minimum": 1 },
        "featured": { "type": "boolean" }
      }
    }
  }
}
