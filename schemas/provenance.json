{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alephbits.org/schemas/provenance.json",
  "title": "AlephBits Editorial Provenance",
  "description": "provenance.json — editorial audit trail for official packs.",
  "type": "object",
  "required": ["packId", "editorialStatus", "createdAt", "editors", "sources"],
  "additionalProperties": false,
  "properties": {
    "packId": { "type": "string", "minLength": 1 },
    "bookId": { "type": "string", "minLength": 1 },
    "editorialStatus": {
      "type": "string",
      "enum": ["official", "community", "experimental"]
    },
    "createdAt": { "type": "string", "format": "date" },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "editors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "aiAssistance": {
      "type": "object",
      "properties": {
        "used": { "type": "boolean" },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "humanReview": { "type": "string" }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "videoId"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "youtube" },
              "videoId": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]{11}$"
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "description"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["original", "public_domain", "licensed", "adaptation"]
              },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    },
    "revisionNotes": { "type": "string" }
  }
}
